{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2022"],
    "strict": false,
    "skipLibCheck": true,
    "types": ["node", "express"]
  },
  "include": [
    "shared/contracts.js",
    "server/config.js",
    "server/routes/*.js",
    "server/services/**/*.js",
    "server/utils/*.js"
  ]
}
