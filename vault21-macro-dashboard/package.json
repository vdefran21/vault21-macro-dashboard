{
  "name": "vault21-macro-dashboard",
  "version": "1.0.0",
  "description": "Private credit crisis monitoring dashboard — vault21 macro intelligence",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon server/index.js",
    "dev:client": "npm --prefix client run dev",
    "start": "node server/index.js",
    "seed": "node server/db/seed.js",
    "setup": "npm install && node server/db/seed.js"
  },
  "private": true,
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14"
  }
}