{
  "name": "vault21-macro-dashboard",
  "version": "1.0.0",
  "description": "Private credit crisis monitoring dashboard — vault21 macro intelligence",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon server/index.js",
    "dev:client": "npm --prefix client run dev",
    "start": "node server/index.js",
    "seed": "node server/db/seed.js",
    "setup": "npm install && node server/db/seed.js",
    "check:types": "npm run check:types:server && npm run check:types:client",
    "check:types:server": "tsc -p tsconfig.typecheck.server.json",
    "check:types:client": "tsc -p tsconfig.typecheck.client.json"
  },
  "private": true,
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "better-sqlite3": "^12.6.2",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "node-fetch": "^2.7.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/node-fetch": "^2.6.13",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "typescript": "^5.9.3"
  }
}
