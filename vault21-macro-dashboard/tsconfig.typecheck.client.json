{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": false,
    "skipLibCheck": true
  },
  "include": [
    "shared/contracts.js",
    "client/src/lib/api.js",
    "client/src/hooks/useDashboardData.js"
  ]
}
